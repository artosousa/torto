<div id="dealerCode" class="container"></div>

{% style %}
  #shopify-section-{{ section.id }} {
      padding: 20px 20px 0;
      display: flex;
      justify-content: center;
      align-items: center; 
      width: 100%;
  }
  #shopify-section-{{ section.id }} .container{
    width: 100%;
    max-width: 1400px;
    text-align: right;
    padding-right: 40px;
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      display: none;
    }
  }
{% endstyle %}
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const dealerCodeElement = document.getElementById("dealerCode");
        if (!dealerCodeElement) return;

        function appliedCodeFromCart(cart) {
            if (!cart) return null;
            var codes = cart.discount_codes;
            if (codes && codes.length) {
                var entry = codes[codes.length - 1];
                if (typeof entry === "string") {
                    var s = entry.trim();
                    return s || null;
                }
                if (entry && entry.code) {
                    var c = String(entry.code).trim();
                    return c || null;
                }
            }
            var apps =
                cart.cart_level_discount_applications || cart.discount_applications;
            if (!apps || !apps.length) return null;
            for (var i = apps.length - 1; i >= 0; i--) {
                var a = apps[i];
                if (a && a.type === "discount_code" && a.title) {
                    var t = String(a.title).trim();
                    if (t) return t;
                }
            }
            return null;
        }

        var cartJsUrl =
            window.routes && window.routes.cart_url
                ? window.routes.cart_url + ".js"
                : "/cart.js";

        fetch(cartJsUrl, { credentials: "same-origin" })
            .then(function (res) {
                return res.json();
            })
            .then(function (cart) {
                const codeApplied = appliedCodeFromCart(cart);
                window.codeApplied = codeApplied;
                if (codeApplied) {
                    localStorage.setItem("dealerDiscountCode", codeApplied);
                }
                const displayCode =
                    codeApplied || localStorage.getItem("dealerDiscountCode");
                if (displayCode) {
                    dealerCodeElement.innerHTML =
                        '<h2 style="line-height: 1.5rem; font-size:2rem;">10% OFF DEALER CODE <strong style="color:#6fb321">' +
                        displayCode +
                        "</strong></h2>";
                } else {
                    dealerCodeElement.innerHTML = "";
                }
            })
            .catch(function () {
                window.codeApplied = null;
                const displayCode = localStorage.getItem("dealerDiscountCode");
                if (displayCode) {
                    dealerCodeElement.innerHTML =
                        '<h2 style="line-height: 1.5rem; font-size:2rem;">10% OFF DEALER CODE <strong style="color:#6fb321">' +
                        displayCode +
                        "</strong></h2>";
                } else {
                    dealerCodeElement.innerHTML = "";
                }
            });
    });
</script>
{% schema %}
{
  "name": "Dealer Code",
  "tag": "section",
  "class": "dealer-code-section",
  "presets": [
    {
      "name": "Dealer Code"
    }
  ]
}
{% endschema %}