<div id="discount-code" class="discount-code" data-mobile-tab aria-hidden="true"></div>

{% style %}
  #discount-code {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background-color: rgba(111, 179, 33, 1);
    border-radius: 8px;
    margin-top: 20px;
    position: fixed;
    z-index: 10;
    bottom: 1%;
    left: 1%;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  #discount-code h2 {
    color: #fff;
    font-size: 1.5rem !important;
    margin: 0;
  }

  /* Mobile: tab on the side; click to expand */
  @media (max-width: 768px) {
    #discount-code {
      bottom: auto;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      margin-top: 0;
      padding: 12px 10px;
      border-radius: 0 8px 8px 0;
      box-shadow: 2px 0 8px rgba(0,0,0,0.15);
      cursor: pointer;
    }
    #discount-code[data-mobile-tab].discount-code--tab {
      padding: 18px 10px;
      min-width: auto;
      width: auto;
      max-width: 52px;
    }
    #discount-code[data-mobile-tab].discount-code--tab .discount-code__content {
      display: none;
    }
    #discount-code[data-mobile-tab].discount-code--tab .discount-code__tab-label {
      display: block;
    }
    #discount-code[data-mobile-tab]:not(.discount-code--visible) {
      opacity: 0;
      pointer-events: none;
      transform: translateX(-100%) translateY(-50%);
    }
    #discount-code[data-mobile-tab].discount-code--visible.discount-code--tab {
      transform: translateX(0) translateY(-50%);
    }
    #discount-code[data-mobile-tab].discount-code--visible:not(.discount-code--tab) {
      transform: translateX(0) translateY(-50%);
      max-width: min(280px, 85vw);
      padding: 16px 14px;
    }
    .discount-code__tab-label {
      display: none;
      color: #fff;
      font-size: 2rem;
      font-weight: 700;
      line-height: 1.2;
      text-align: center;
      writing-mode: vertical-rl;
      text-orientation: mixed;
      letter-spacing: 0.05em;
    }
  }

  @media (min-width: 769px) {
    .discount-code__tab-label { display: none !important; }
  }
{% endstyle %}
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const dealerCodeElement = document.getElementById("discount-code");
        if (!dealerCodeElement) return;

        const isMobile = () => window.innerWidth <= 768;

        function appliedCodeFromCart(cart) {
            if (!cart) return null;
            var codes = cart.discount_codes;
            if (codes && codes.length) {
                var entry = codes[codes.length - 1];
                if (typeof entry === "string") {
                    var s = entry.trim();
                    return s || null;
                }
                if (entry && entry.code) {
                    var c = String(entry.code).trim();
                    return c || null;
                }
            }
            var apps =
                cart.cart_level_discount_applications || cart.discount_applications;
            if (!apps || !apps.length) return null;
            for (var i = apps.length - 1; i >= 0; i--) {
                var a = apps[i];
                if (a && a.type === "discount_code" && a.title) {
                    var t = String(a.title).trim();
                    if (t) return t;
                }
            }
            return null;
        }

        function setupBadge(displayCode) {
            if (!displayCode) {
                dealerCodeElement.innerHTML = "";
                dealerCodeElement.removeAttribute("data-mobile-tab");
                return;
            }

            dealerCodeElement.innerHTML = [
                '<span class="discount-code__tab-label" aria-hidden="true">10% OFF</span>',
                '<div class="discount-code__content">',
                '<h2 style="line-height: 1.5rem; font-size: 1.5rem;">10% OFF DEALER CODE <strong style="color:#fff">' +
                    displayCode +
                    "</strong></h2>",
                "</div>",
            ].join("");

            if (!isMobile()) {
                dealerCodeElement.removeAttribute("aria-hidden");
                return;
            }

            dealerCodeElement.setAttribute("aria-hidden", "true");
            dealerCodeElement.classList.add("discount-code--tab");

            const showAsTab = () => {
                dealerCodeElement.classList.add("discount-code--visible");
                dealerCodeElement.setAttribute("aria-hidden", "false");
            };

            const toggleExpand = () => {
                dealerCodeElement.classList.toggle("discount-code--tab");
            };

            showAsTab();

            dealerCodeElement.addEventListener("click", function (e) {
                if (!isMobile()) return;
                e.preventDefault();
                toggleExpand();
            });

            window.addEventListener(
                "scroll",
                function () {
                    if (!isMobile()) return;
                    if (!dealerCodeElement.classList.contains("discount-code--tab")) {
                        dealerCodeElement.classList.add("discount-code--tab");
                    }
                },
                { passive: true }
            );
        }

        var cartJsUrl =
            window.routes && window.routes.cart_url
                ? window.routes.cart_url + ".js"
                : "/cart.js";

        fetch(cartJsUrl, { credentials: "same-origin" })
            .then(function (res) {
                return res.json();
            })
            .then(function (cart) {
                const codeApplied = appliedCodeFromCart(cart);
                window.codeApplied = codeApplied;
                if (codeApplied) {
                    localStorage.setItem("dealerDiscountCode", codeApplied);
                }
                const displayCode =
                    codeApplied || localStorage.getItem("dealerDiscountCode");
                setupBadge(displayCode);
            })
            .catch(function () {
                window.codeApplied = null;
                setupBadge(localStorage.getItem("dealerDiscountCode"));
            });
    });
</script>